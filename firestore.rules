rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }
    match /archive_items/{itemId} {
      allow read: if resource.data.status == "approved" || (signedIn() && resource.data.createdBy == request.auth.uid) || signedIn();
      allow create: if signedIn() && request.resource.data.status == "pending" && request.resource.data.createdBy == request.auth.uid;
      allow update, delete: if signedIn();
    }
    match /members/{uid} {
      allow read: if signedIn();
      allow create: if isOwner(uid);
      allow update: if signedIn();
    }
  }
}
